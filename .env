VITE_SUPABASE_URL=test
VITE_SUPABASE_PUBLISHABLE_KEY=test
VITE_MERCADOPAGO_PUBLIC_KEY=test
MERCADOPAGO_ACCESS_TOKEN=test

# Google OAuth - Configurar en Supabase Dashboard > Authentication > Providers > Google
# y en https://console.cloud.google.com/apis/credentials
VITE_GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID

# JWT Secret - Se usa automáticamente desde Supabase (no modificar)
# SUPABASE_JWT_SECRET se configura en el dashboard de Supabase

# App Config
VITE_APP_URL=http://localhost:5173
VITE_APP_NAME=MiTienda
